# Test environment configuration
NODE_ENV=test
PORT=4001

# Database (use separate test database)
DATABASE_URL="postgresql://auth_user:auth_password@localhost:5432/auth_db_test?schema=public"

# JWT Configuration
JWT_ISSUER=http://localhost:4001
JWT_AUDIENCE=auth-service-api-test
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Key Management
AUTH_KEY_ENCRYPTION_SECRET=test-encryption-secret-32-chars-min

# Internal Service
INTERNAL_SERVICE_TOKEN=test-internal-service-token-32-chars-minimum

# Rate Limiting (relaxed for tests)
RATE_LIMIT_AUTH_MAX=1000
RATE_LIMIT_AUTH_WINDOW_MS=60000

# Logging
LOG_LEVEL=error
