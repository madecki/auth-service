# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=4001

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=auth_password
POSTGRES_DB=auth_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# =============================================================================
# JWT Configuration
# =============================================================================
# Issuer claim for access tokens (should be your service URL in production)
JWT_ISSUER=http://localhost:4000

# Audience claim for access tokens (typically your API or app identifier)
JWT_AUDIENCE=auth-service-api

# Access token TTL (in seconds) - default 15 minutes
ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token TTL (in seconds) - default 30 days
REFRESH_TOKEN_TTL_SECONDS=2592000

# =============================================================================
# Key Management
# =============================================================================
# Master key for encrypting private keys in database (32+ chars recommended)
# Generate with: openssl rand -base64 32
AUTH_KEY_ENCRYPTION_SECRET=your-32-char-encryption-secret-here

# Key rotation settings
KEY_ROTATION_ENABLED=false
KEY_ROTATION_INTERVAL_HOURS=720

# =============================================================================
# Internal Service Authentication
# =============================================================================
# Token for internal endpoints like /internal/keys/rotate
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# =============================================================================
# Rate Limiting
# =============================================================================
# Max requests per window for auth endpoints
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=debug

# =============================================================================
# pgAdmin (optional, for local dev)
# =============================================================================
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
